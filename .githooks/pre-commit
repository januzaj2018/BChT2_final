#!/bin/bash

# Pre-commit hook: Solidity code formatting and Frontend Prettier

set -e

echo "Running pre-commit checks..."

# Check if forge is installed
if ! command -v forge &> /dev/null; then
    echo "ERROR: forge not found. Please install Foundry"
    exit 1
fi

# Format Solidity code
echo "Formatting Solidity code with forge..."
forge fmt

# Format Frontend code if exists
if [ -d "frontend" ]; then
    echo "Formatting frontend code with Prettier..."
    cd frontend && npx prettier --write "src/**/*.{js,jsx,ts,tsx,css,json}" && cd ..
fi

# Run solhint if available
if command -v solhint &> /dev/null; then
    echo "Running solhint..."
    solhint 'src/**/*.sol' || true
fi

echo "Pre-commit checks passed and formatting applied."
